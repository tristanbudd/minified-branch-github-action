{
  "name": "minified-branch-github-action",
  "version": "1.0.0",
  "description": "CSS Build & Minify Pipeline | GitHub Action | Generates Production Branch | Minifies CSS & JS | Rewrites Asset Links | Keeps Source Clean",
  "keywords": [
    "github-actions",
    "ci",
    "css",
    "javascript",
    "js",
    "minify",
    "build",
    "deployment",
    "branch",
    "automation",
    "pipeline"
  ],
  "homepage": "https://github.com/tristanbudd/minified-branch-github-action",
  "repository": {
    "type": "git",
    "url": "https://github.com/tristanbudd/minified-branch-github-action.git"
  },
  "bugs": {
    "url": "https://github.com/tristanbudd/minified-branch-github-action/issues"
  },
  "license": "MIT",
  "author": "Tristan Budd <contact@tristanbudd.com>",
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node20 --outfile=dist/index.js --conditions=import",
    "dev": "node src/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.0",
    "clean-css": "^5.3.3",
    "terser": "^5.46.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
