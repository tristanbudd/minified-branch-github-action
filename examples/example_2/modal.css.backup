/* =========================================
   Example 2: Modal Stylesheet
=========================================
*/

body {
  margin: 0;
  font-family: Arial, sans-serif;
}

.page-wrapper {
  padding: 50px;
  text-align: center;
}

.action-btn,
.close-btn {
  padding: 10px 20px;
  background-color: #007bff;
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
}

.close-btn {
  background-color: #6c757d;
  margin-top: 20px;
}

/* Modal Overlay Styling */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content-box {
  background-color: white;
  padding: 30px;
  border-radius: 8px;
  width: 80%;
  max-width: 500px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

/* Utility class to hide elements via JavaScript */
.hidden {
  display: none !important;
}
